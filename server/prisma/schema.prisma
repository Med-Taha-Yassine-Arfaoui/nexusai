generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  reports   Report[]
}

model Report {
  id        String   @id @default(uuid())
  query     String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
model MarketData {
  id              Int      @id @default(autoincrement())
  codeisin        String?
  mnemo           String?
  last_trade_price Float?
  quantity        Float?
  var_prev_close  Float?
  time            DateTime?
  ingested_at     DateTime?
}